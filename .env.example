# Docker Compose environment variables
# Copy this file to .env and change the passwords before first run:
#   cp .env.example .env
#
# These values are referenced by docker-compose.yml.
# SQL Server passwords must meet complexity requirements:
#   - At least 8 characters
#   - Uppercase + lowercase + digit + special character

# ── Database Passwords ─────────────────────────────────────────────────
ORDERS_DB_PASSWORD=<your-secure-password-here>
INVENTORY_DB_PASSWORD=<your-secure-password-here>

# ── Notes ──────────────────────────────────────────────────────────────
# RabbitMQ credentials (guest/guest) are configured directly in
# docker-compose.yml. Override them there if needed.
#
# Service ports (defaults):
#   Gateway:       http://localhost:8080
#   Orders API:    http://localhost:5001  (dev override only)
#   Inventory API: http://localhost:5002  (dev override only)
#   RabbitMQ UI:   http://localhost:15672
#   Seq UI:        http://localhost:8081
